NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/maintainiq?retryWrites=true&w=majority

# JWT secrets - generate strong random values for production, e.g. `openssl rand -hex 64`
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin allowed by CORS, and the base URL encoded into QR codes
CLIENT_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173

# Cloudinary (evidence uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini (AI Issue Triage)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
